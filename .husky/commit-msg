# Ensure the repo's Node (via nvm/.nvmrc) is on PATH before commitlint.
# Sourced — not executed — so nvm's PATH changes persist in this shell.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck disable=SC1091
. "$REPO_ROOT/scripts/check-node-version.sh"

# Validate the commit message against Conventional Commits (drives changelog generation)
npx --no-install commitlint --edit "$1"
