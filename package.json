{
  "name": "@reggieofarrell/firestore-orm",
  "version": "2.2.1",
  "description": "Type-safe Firestore ORM with validation, lifecycle hooks, and a powerful query builder. Built for Firebase Admin SDK with full TypeScript support.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./vector": {
      "import": {
        "types": "./dist/vector/index.d.ts",
        "default": "./dist/vector/index.js"
      },
      "require": {
        "types": "./dist/cjs/vector/index.d.ts",
        "default": "./dist/cjs/vector/index.js"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express/index.d.ts",
        "default": "./dist/express/index.js"
      },
      "require": {
        "types": "./dist/cjs/express/index.d.ts",
        "default": "./dist/cjs/express/index.js"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf dist .tsbuildinfo coverage",
    "build": "rimraf dist && tsc && tsc -p tsconfig.cjs.json && node scripts/finalize-dual-build.mjs",
    "prepublishOnly": "npm run build",
    "release:bump": "commit-and-tag-version --skip.tag",
    "release:bump:dry": "commit-and-tag-version --dry-run --skip.tag",
    "release:publish": "gh release create v$npm_package_version --target main --title v$npm_package_version --generate-notes",
    "emulator:start": "firebase emulators:start --project demo-firestoreorm-test --only firestore",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:dev": "npm --prefix website run dev",
    "docs:build": "npm --prefix website run build",
    "check:docs": "node scripts/check-doc-links.mjs",
    "test:types": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "npm run test:unit && npm run test:integration:emulator",
    "test:unit": "jest --config jest.config.unit.js",
    "test:unit:coverage": "jest --config jest.config.unit.js --coverage",
    "test:integration": "jest --config jest.config.integration.js",
    "test:integration:coverage": "firebase emulators:exec --project demo-firestoreorm-test --only firestore \"jest --config jest.config.integration.js --coverage\"",
    "test:integration:emulator": "firebase emulators:exec --project demo-firestoreorm-test --only firestore \"npm run test:integration\"",
    "test:coverage:gate:unit": "node scripts/check-coverage-gates.mjs --suite unit",
    "test:coverage:gate:integration": "node scripts/check-coverage-gates.mjs --suite integration",
    "test:coverage:all": "npm run test:unit:coverage && npm run test:coverage:gate:unit && npm run test:integration:coverage && npm run test:coverage:gate:integration",
    "test:watch": "jest --config jest.config.unit.js --watch",
    "test:performance": "ts-node-dev --respawn --transpile-only ./src/benchmarks/performance.test.ts"
  },
  "keywords": [
    "firestore",
    "orm",
    "firebase",
    "firebase-admin",
    "typescript",
    "type-safe",
    "database",
    "nosql",
    "cloud-firestore",
    "google-cloud",
    "repository-pattern",
    "validation",
    "zod",
    "vector-search",
    "transaction",
    "batch-operations",
    "pagination",
    "hooks",
    "lifecycle",
    "data-layer",
    "backend",
    "node",
    "server-side",
    "firebase-orm",
    "firestore-wrapper",
    "firestore-repository",
    "fireorm-altenative",
    "typesaurus-altenative",
    "typeorm-alternative",
    "prisma-alternative"
  ],
  "author": {
    "name": "Reggie O'Farrell",
    "email": "reggie@blackflag.design",
    "url": "https://github.com/reggieofarrell"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reggieofarrell/firestore-orm"
  },
  "bugs": {
    "url": "https://github.com/reggieofarrell/firestore-orm/issues"
  },
  "homepage": "https://reggieofarrell.github.io/firestore-orm/",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "firebase-admin": "^12.0.0 || ^13.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "firebase-admin": "^13.0.0",
    "firebase-tools": "^14.27.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
